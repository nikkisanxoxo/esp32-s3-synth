{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Set Target",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py set-target esp32s3",
            "group": "build",
            "presentation": { "panel": "shared", "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "Build",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py build",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "panel": "shared", "reveal": "always" },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Flash",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py flash",
            "group": "build",
            "presentation": { "panel": "shared", "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "Monitor",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py monitor",
            "group": "build",
            "presentation": { "panel": "dedicated", "reveal": "always" }
        },
        {
            "label": "Flash & Monitor",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py flash monitor",
            "group": "build",
            "presentation": { "panel": "dedicated", "reveal": "always" }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": ". ~/.espressif/esp-idf/export.sh && idf.py fullclean",
            "group": "build",
            "presentation": { "panel": "shared", "reveal": "always" }
        }
    ]
}
